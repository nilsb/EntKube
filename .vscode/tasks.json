{
  "version": "2.0.0",
  "tasks": [
    {
      // Copies .env.example → .env if .env is missing, so the debugger's
      // envFile setting never fails with ENOENT on a fresh clone.
      "label": "ensure: .env exists",
      "type": "shell",
      "command": "test -f .env || cp .env.example .env",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "build: backend",
      "type": "shell",
      "command": "go build ./...",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$go"
    },
    {
      "label": "build: frontend",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "test: backend",
      "type": "shell",
      "command": "go test ./...",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "problemMatcher": "$go"
    },
    {
      "label": "test: frontend",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "typecheck: frontend",
      "type": "shell",
      "command": "npm run typecheck",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": "$tsc"
    },
    {
      "label": "docker: dev (single node)",
      "type": "shell",
      "command": "docker compose up --build",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "docker: HA (two nodes)",
      "type": "shell",
      "command": "docker compose -f docker-compose.ha.yml up --build",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
