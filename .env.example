# .env.example — single-node dev/debug
# Copy to .env and fill in the secrets before running:
#   docker compose up --build

# ── Postgres ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Vault encryption ─────────────────────────────────────────────
# One AES-256 root key per node, base64-encoded.
# Generate: openssl rand -base64 32
VAULT_ROOT_KEY=REPLACE_WITH_BASE64_AES256_KEY

# ── JWT signing ───────────────────────────────────────────────────
# Shared across all nodes so tokens from any node are accepted.
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_BASE64_HMAC_KEY

# ── HA join token ─────────────────────────────────────────────────
# A new node must present this token to /api/ha/join.
# Generate: openssl rand -hex 32
HA_JOIN_TOKEN=REPLACE_WITH_RANDOM_HEX

# ── Bootstrap admin ───────────────────────────────────────────────
# If set and no users exist yet, an admin account is created on first startup.
# Remove or clear these after the first run.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Git webhook ───────────────────────────────────────────────────
# Embedded in the webhook URL: POST /api/webhooks/git/<secret>
# Register this URL in GitHub/GitLab push-event webhooks.
# Generate: openssl rand -hex 32
WEBHOOK_GIT_SECRET=REPLACE_WITH_RANDOM_HEX
