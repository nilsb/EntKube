# .env.ha.example — copy to .env and fill in real values before running
# docker compose -f docker-compose.ha.yml up

POSTGRES_PASSWORD=change_me_strong_password

# Each node needs its own 32-byte (256-bit) AES key, base64-encoded.
# Generate with: openssl rand -base64 32
VAULT_ROOT_KEY_NODE1=REPLACE_WITH_BASE64_AES256_KEY_FOR_NODE1
VAULT_ROOT_KEY_NODE2=REPLACE_WITH_BASE64_AES256_KEY_FOR_NODE2

# Shared JWT signing key — all nodes must have the same value so that
# a token issued on node-1 is accepted by node-2.
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_BASE64_HMAC_KEY

# One-time token that a new node must present to /api/ha/join.
# Generate with: openssl rand -hex 32
HA_JOIN_TOKEN=REPLACE_WITH_RANDOM_HEX_JOIN_TOKEN

# Public hostname/domain for the Caddy load balancer
DOMAIN=entkube.example.com

# Bootstrap: if ADMIN_EMAIL and ADMIN_PASSWORD are set and no users exist in
# the DB, an admin account is created on first startup. Remove after first run.
# Generate password with: openssl rand -hex 16
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Git webhook secret — embedded in the webhook URL you register in GitHub/GitLab:
#   POST https://<domain>/api/webhooks/git/<secret>
# Generate with: openssl rand -hex 32
WEBHOOK_GIT_SECRET=REPLACE_WITH_RANDOM_HEX
